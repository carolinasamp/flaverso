#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Use commitlint if available; fall back to simple regex if not.
if command -v npx >/dev/null 2>&1; then
  npx --no -- commitlint --edit "$1"
  exit_code=$?
  if [ $exit_code -ne 0 ]; then
    echo "\nERROR: commitlint failed. Please fix your commit message."
    exit $exit_code
  fi
else
  # simple regex validator
  commit_msg_file="$1"
  commit_msg=$(sed -n '1p' "$commit_msg_file")
  regex='^(feat|fix|chore|docs|refactor|test|style|perf|ci|build)(\([a-z0-9\-]+\))?: .{1,50}'
  if ! echo "$commit_msg" | grep -E "$regex" >/dev/null; then
    echo "\nERROR: Commit message does not follow Conventional Commits format."
    echo "Expected: type(scope): short description"
    echo "Example: feat(ui): add Button component\n"
    exit 1
  fi
fi

exit 0
npx --no -- commitlint --edit "$1"
npx --no -- commitlint --edit "$1"
npx --no -- commitlint --edit "$1"
npx --no -- commitlint --edit "$1"
