{
  "name": "flaverso",
  "version": "0.1.1",
  "private": true,
  "description": "Flaverso - reading platform",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "prepare": "husky install",
    "commitlint": "commitlint --edit $1",
    "release": "standard-version",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "build": "tsc -b",
    "build:packages": "for d in packages/*; do [ -f \"$d/package.json\" ] && (cd \"$d\" && npm run build || true); done",
    "build:web": "(cd apps/web && npm run build || true)",
    "build:api": "(cd apps/api && npm run build || true)",
    "build:all": "npm run build && npm run build:packages && npm run build:web && npm run build:api"
  },
  "scripts": {
    "lerna:bootstrap": "npx lerna bootstrap --hoist",
    "lerna:publish": "npx lerna publish",
    "lerna:version": "npx lerna version",
    "ci:bootstrap": "npx lerna bootstrap --no-ci",
    "ci:build": "npm run build:all"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lerna": {
    "version": "independent",
    "packages": [
      "packages/*",
      "apps/*"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/carolinasamp/Flaverso.git"
  },
  "author": "casrocha",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.0"
  }
}
